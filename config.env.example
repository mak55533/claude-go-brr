# Claude integration delegates to ../../../../offload.sh.
# Store client auth in ~/.config/offload/config:
#
# OFFLOAD_API_URL=https://accelerator.functio.ai
# OFFLOAD_API_KEY=off_client_...
# OFFLOAD_GITHUB_LOGIN=octocat
#
# Optional:
# OFFLOAD_REMOTE=origin  # explicit override; otherwise selected from OFFLOAD_GITHUB_LOGIN
# OFFLOAD_POLL_INTERVAL=5
# OFFLOAD_POLL_TIMEOUT=3600
